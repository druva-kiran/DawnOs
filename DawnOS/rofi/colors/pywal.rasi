/**
 * Pywal template — DO NOT edit this file directly
 * Place at: ~/.config/wal/templates/pywal.rasi
 * Auto-output to: ~/.cache/wal/pywal.rasi
 **/

* {
    background:     {background}ff;
    background-alt: {color0}ff;
    foreground:     {foreground}ff;
    selected:       {color3}ff;
    active:         {color1}ff;
    urgent:         {color2}ff;
}
