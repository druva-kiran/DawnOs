(deflisten visualizer_output :initial "" "scripts/visualizer.sh")

(defwidget visualizer []
  (box :class "visualizer-box" :orientation "h" :halign "center" :valign "center"
    (label :class "visualizer-text" :text "${visualizer_output}" :angle 0 :truncate false)
  )
)

(defwindow visualizer_win
  :monitor 0
  :geometry (geometry :x "20px" :y "20px" :width "350px" :height "120px" :anchor "bottom left")
  :stacking "bottom"
  :exclusive false
  (visualizer)
)